# Required for DashScope / Alibaba Tongyi model calls
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Optional LangSmith tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=rag-langgraph-local

# Model settings
QWEN_MODEL=qwen-vl-max
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# Local Chroma vector database path
CHROMA_DIR=.chroma
COLLECTION_NAME=rag-chroma

# Source URLs, comma-separated
SOURCE_URLS=https://lilianweng.github.io/posts/2023-06-23-agent/,https://lilianweng.github.io/posts/2023-03-15-prompt-engineering/,https://lilianweng.github.io/posts/2023-10-25-adv-attack-llm/
